{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build debug CPU",
      "type": "shell",
      "command": "${workspaceFolder}/build",
      "args": [
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "${workspaceFolder}/test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
