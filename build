#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${1:-}" == "debug" || "${1:-}" == "release" ]]; then
  mode="$1"
  shift
  exec "$ROOT_DIR/tools/mcp_tools.sh" --mode "$mode" --cuda off "$@"
fi

if [[ $# -eq 0 ]]; then
  "$ROOT_DIR/tools/mcp_tools.sh" --mode debug --cuda off
  "$ROOT_DIR/tools/mcp_tools.sh" --mode release --cuda off
  exit 0
fi

exec "$ROOT_DIR/tools/mcp_tools.sh" "$@"
